{
  "name": "agentreceipt",
  "version": "0.1.0",
  "description": "Portable signed attestations for consequential agent actions crossing trust boundaries.",
  "homepage": "https://boundaryattest.com",
  "type": "module",
  "private": true,
  "license": "MIT",
  "bin": {
    "agentreceipt": "dist/src/index.js"
  },
  "exports": {
    ".": "./dist/src/public.js"
  },
  "types": "./dist/src/public.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "setup": "node dist/src/index.js setup",
    "demo": "node dist/src/index.js demo",
    "verify": "node dist/src/index.js verify",
    "chain": "node dist/src/index.js chain",
    "chain:retained": "node dist/src/index.js chain:retained",
    "prune": "node dist/src/index.js prune",
    "example:wrap": "node dist/examples/wrap-fake-tool.js",
    "example:sink": "node dist/examples/custom-sink-demo.js",
    "example:mcp": "node dist/examples/mcp-style-demo.js",
    "example:mcp-real": "node dist/examples/mcp-real-demo.js",
    "example:mcp-server": "node dist/examples/mcp-server-receipt-demo.js",
    "example:trust-boundary": "node dist/examples/trust-boundary-demo.js",
    "example:intergrax-poc": "node dist/examples/intergrax-poc/run.js",
    "example:proof-kit": "node dist/examples/proof-kit/verify-proof-kit.js",
    "reset:demo": "node scripts/reset-demo.mjs",
    "reset:all": "node scripts/reset-all.mjs",
    "demo:clean": "npm run reset:demo && npm run build && npm run example:mcp-real && npm run chain"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
